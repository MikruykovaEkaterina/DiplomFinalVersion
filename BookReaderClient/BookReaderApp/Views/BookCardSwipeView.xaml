<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:BookReaderApp.Views"
             x:Class="BookReaderApp.Views.BookCardSwipeView">

  <Grid x:Name="SwipeContainer" RowDefinitions="*,Auto">

    <views:BookCardView x:Name="CurrentCardView" 
                        Grid.Row="0"
                        BookTapped="OnBookTapped"
                        BindingContext="{Binding CurrentBook}" />

      <!-- Версии: тап по краям; по центру — стрелки масштабируются с размером интерфейса. -->
      <Grid x:Name="VersionIndicator"
            Grid.Row="1"
            IsVisible="False"
            ColumnDefinitions="*,Auto,*"
            Margin="0,2,0,2"
            HeightRequest="{DynamicResource UiSwipeVersionArrowSize}"
            VerticalOptions="Center">
        <Grid x:Name="VersionTapLeft"
              Grid.Column="0"
              BackgroundColor="Transparent"
              VerticalOptions="Fill"
              HorizontalOptions="Fill" />
        <HorizontalStackLayout Grid.Column="1"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Spacing="4">
          <Grid x:Name="LeftArrowHost"
                WidthRequest="{DynamicResource UiSwipeVersionArrowSize}"
                HeightRequest="{DynamicResource UiSwipeVersionArrowSize}"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                BackgroundColor="Transparent">
            <Image x:Name="LeftArrow"
                   Source="{DynamicResource UiIconArrowLeft}"
                   WidthRequest="{DynamicResource UiSwipeVersionArrowSize}"
                   HeightRequest="{DynamicResource UiSwipeVersionArrowSize}"
                   Opacity="0.35"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
          </Grid>

          <HorizontalStackLayout x:Name="DotsContainer"
                                 Spacing="4"
                                 VerticalOptions="Center" />

          <Grid x:Name="RightArrowHost"
                WidthRequest="{DynamicResource UiSwipeVersionArrowSize}"
                HeightRequest="{DynamicResource UiSwipeVersionArrowSize}"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                BackgroundColor="Transparent">
            <Image x:Name="RightArrow"
                   Source="{DynamicResource UiIconArrowRight}"
                   WidthRequest="{DynamicResource UiSwipeVersionArrowSize}"
                   HeightRequest="{DynamicResource UiSwipeVersionArrowSize}"
                   Opacity="0.35"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
          </Grid>
        </HorizontalStackLayout>
        <Grid x:Name="VersionTapRight"
              Grid.Column="2"
              BackgroundColor="Transparent"
              VerticalOptions="Fill"
              HorizontalOptions="Fill" />
      </Grid>
  </Grid>
</ContentView>
