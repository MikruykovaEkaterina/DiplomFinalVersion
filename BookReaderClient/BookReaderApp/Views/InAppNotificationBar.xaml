<?xml version="1.0" encoding="utf-8" ?>
<Border xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        x:Class="BookReaderApp.Views.InAppNotificationBar"
        StrokeThickness="1"
        Padding="14,12"
        Margin="16,0,16,10">
  <Border.StrokeShape>
    <RoundRectangle CornerRadius="8" />
  </Border.StrokeShape>
  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" RowSpacing="0">
    <Label x:Name="MessageLabel"
           Grid.Column="0"
           FontSize="{DynamicResource MainFontSize}"
           LineBreakMode="WordWrap"
           VerticalOptions="Center"
           HorizontalOptions="Fill" />
    <Label x:Name="CloseGlyph"
           Grid.Column="1"
           Text="×"
           FontSize="{DynamicResource UiDismissIconSize}"
           VerticalOptions="Center"
           HorizontalTextAlignment="Center"
           VerticalTextAlignment="Center"
           MinimumWidthRequest="{DynamicResource UiDismissTapMinSize}"
           MinimumHeightRequest="{DynamicResource UiDismissTapMinSize}"
           WidthRequest="{DynamicResource UiDismissTapMinSize}"
           HeightRequest="{DynamicResource UiDismissTapMinSize}">
      <Label.GestureRecognizers>
        <TapGestureRecognizer Tapped="OnCloseTapped" />
      </Label.GestureRecognizers>
    </Label>
  </Grid>
  <Border.GestureRecognizers>
    <SwipeGestureRecognizer Direction="Down" Swiped="OnSwipedDown" />
  </Border.GestureRecognizers>
</Border>
